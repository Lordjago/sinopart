# ---------------------------------------------------------------------------
# SinoPart backend — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values. `.env` is git-ignored so your
# secrets never get committed. NestJS reads these via @nestjs/config (see
# src/app.module.ts) and they are validated on boot (src/config/env.validation.ts).

# The TCP port the HTTP server listens on.
PORT=3000

# Where the browser frontend runs. Used to configure CORS so the React app is
# allowed to call this API from a different origin. Comma-separate multiple.
CORS_ORIGIN=http://localhost:5173

# MongoDB connection string.
#  - Local MongoDB:  mongodb://localhost:27017/sinopart
#  - MongoDB Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sinopart
MONGODB_URI=mongodb://localhost:27017/sinopart

# Secret used to sign JWTs. MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-string

# How long an access token stays valid. The frontend's mock issued 8h tokens,
# so we mirror that. Accepts values like 60, "2 days", "10h", "7d".
JWT_EXPIRES_IN=8h

# ---------------------------------------------------------------------------
# Email (sendbyte.africa)
# ---------------------------------------------------------------------------
# All three are REQUIRED. SendByte is the only mail adapter, so the app refuses
# to boot without a full mail configuration — better than discovering at the
# first password reset that nothing can be delivered.
#
# Use a sk_test_ key while developing: SendByte sandboxes those, so you get the
# full send path (and delivery logs in the dashboard) without mailing anyone.

# Secret key from your SendByte dashboard.
# NEVER put a real key in this file — this one is committed to git. Real values
# belong in `.env`, which is git-ignored.
SENDBYTE_API_KEY=sk_test_replace_me

# Sender identity. The domain must be verified in SendByte first, or delivery
# fails. Format: "Display Name <address@domain>".
MAIL_FROM=SinoPart <noreply@example.com>

# Mailbox that receives quote requests and waitlist signup alerts.
ADMIN_EMAIL=admin@example.com
